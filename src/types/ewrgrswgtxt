// Supabase Edge Function: rider-accept-order
// POST { rider_id: <uuid>, order_id: <uuid> }

import { serve } from "https://deno.land/std@0.224.0/http/server.ts";
import { createClient } from "npm:@supabase/supabase-js@2.45.3";

type JsonBody = { rider_id: string; order_id: string };

type ApiOk = { success: true; order_id: string; status: string };
type ApiFail = { success: false; reason: string; message?: string };

type Rider = { id: string; session_token?: string | null };

type Order = {
  id: string;
  rider_id: string | null;
  status: string;
  dealer_id: string;
  mechanic_id: string;
  quote_id: string | null;
  amount: number | string | null;
  distance: number | string | null;
  dealer_lat: number | string | null;
  dealer_lng: number | string | null;
  mechanic_lat: number | string | null;
  mechanic_lng: number | string | null;
};

type UserPhone = { phone: string | null };
type QuoteRow = { quote_details: unknown };

const corsHeaders = {
  "Access-Control-Allow-Origin": "*",
  "Access-Control-Allow-Headers": "authorization, x-client-info, apikey, content-type",
  "Access-Control-Allow-Methods": "POST, OPTIONS",
};

function jsonResponse(body: ApiOk | ApiFail, status = 200) {
  return new Response(JSON.stringify(body), {
    status,
    headers: {
      "Content-Type": "application/json",
      "Connection": "keep-alive",
      ...corsHeaders,
    },
  });
}

function safeJsonParse<T>(text: string): { ok: true; value: T } | { ok: false } {
  try {
    return { ok: true, value: JSON.parse(text) as T };
  } catch {
    return { ok: false };
  }
}

function getBearerToken(req: Request): string | null {
  const h = req.headers.get("Authorization") || "";
  const m = h.match(/^Bearer\s+(.+)$/i);
  return m ? m[1] : null;
}

function haversineMeters(lat1: number, lon1: number, lat2: number, lon2: number): number {
  const R = 6371000; // meters
  const toRad = (d: number) => (d * Math.PI) / 180;
  const dLat = toRad(lat2 - lat1);
  const dLon = toRad(lon2 - lon1);
  const a =
    Math.sin(dLat / 2) * Math.sin(dLat / 2) +
    Math.cos(toRad(lat1)) * Math.cos(toRad(lat2)) *
      Math.sin(dLon / 2) * Math.sin(dLon / 2);
  const c = 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1 - a));
  return R * c;
}

function toNumber(value: unknown) {
  const parsed = Number(value);
  return Number.isFinite(parsed) ? parsed : 0;
}

function roundMoney(value: number) {
  return Math.round(value * 100) / 100;
}

function parseQuoteDetails(value: unknown): unknown[] {
  if (Array.isArray(value)) return value;
  if (typeof value !== "string") return [];
  try {
    const parsed = JSON.parse(value);
    return Array.isArray(parsed) ? parsed : [];
  } catch {
    return [];
  }
}

function firstNumber(row: Record<string, unknown>, keys: string[]) {
  for (const key of keys) {
    const value = Number(row[key]);
    if (Number.isFinite(value)) return value;
  }
  return null;
}

function calculateMrpTotal(items: unknown[], fallbackAmount: number) {
  const total = items.reduce((sum, item) => {
    if (!item || typeof item !== "object") return sum;
    const row = item as Record<string, unknown>;
    const qty = firstNumber(row, ["quantity", "qty"]) ?? 1;
    const mrp =
      firstNumber(row, ["mrp", "MRP", "mrp_price", "mrpPrice", "original_price", "originalPrice"]) ??
      firstNumber(row, ["price", "rate", "unit_price", "unitPrice"]);
    return mrp === null ? sum : sum + mrp * qty;
  }, 0);

  return total > 0 ? total : fallbackAmount;
}

function calculateDeliveryFee(order: Order) {
  const distanceKm = Number(order.distance);
  if (Number.isFinite(distanceKm) && distanceKm > 0) return roundMoney(distanceKm * 3);

  const dealerLat = Number(order.dealer_lat);
  const dealerLng = Number(order.dealer_lng);
  const mechanicLat = Number(order.mechanic_lat);
  const mechanicLng = Number(order.mechanic_lng);

  if (![dealerLat, dealerLng, mechanicLat, mechanicLng].every(Number.isFinite)) return 0;
  return roundMoney((haversineMeters(dealerLat, dealerLng, mechanicLat, mechanicLng) / 1000) * 3);
}

async function sendWhatsAppText(phone: string, text: string) {
  const accessToken = Deno.env.get("WHATSAPP_ACCESS_TOKEN");
  const phoneNumberId = Deno.env.get("WHATSAPP_PHONE_NUMBER_ID");
  if (!accessToken || !phoneNumberId) throw new Error("missing_whatsapp_env");

  const body = {
    messaging_product: "whatsapp",
    to: phone,
    type: "text",
    text: { body: text },
  };

  const res = await fetch(
    `https://graph.facebook.com/v18.0/${phoneNumberId}/messages`,
    {
      method: "POST",
      headers: {
        Authorization: `Bearer ${accessToken}`,
        "Content-Type": "application/json",
      },
      body: JSON.stringify(body),
    },
  );

  if (!res.ok) {
    const txt = await res.text().catch(() => "");
    throw new Error(`whatsapp_failed: ${res.status} ${txt}`);
  }
}

async function requireAuthRider(supabase: ReturnType<typeof createClient>, req: Request): Promise<Rider> {
  const token = getBearerToken(req);
  if (!token) throw new Error("unauthorized");

  const { data, error } = await supabase
    .from("riders")
    .select("id,session_token")
    .eq("session_token", token)
    .maybeSingle();

  if (error) throw error;
  if (!data) throw new Error("unauthorized");
  return data as Rider;
}

async function withTimeout<T>(p: Promise<T>, ms: number): Promise<T> {
  return new Promise((resolve, reject) => {
    const t = setTimeout(() => reject(new Error("timeout")), ms);
    p.then((v) => {
      clearTimeout(t);
      resolve(v);
    }).catch((e) => {
      clearTimeout(t);
      reject(e);
    });
  });
}

serve(async (req) => {
  if (req.method === "OPTIONS") return new Response("ok", { headers: corsHeaders });

  try {
    if (req.method !== "POST") {
      return jsonResponse({ success: false, reason: "method_not_allowed" }, 405);
    }

    const parsed = safeJsonParse<JsonBody>(await req.text());
    if (!parsed.ok || !parsed.value?.rider_id || !parsed.value?.order_id) {
      return jsonResponse({ success: false, reason: "invalid_body", message: "Expected { rider_id, order_id }" }, 400);
    }

    const rider_id = String(parsed.value.rider_id);
    const order_id = String(parsed.value.order_id);

    const supabaseUrl = Deno.env.get("SUPABASE_URL");
    const serviceRoleKey = Deno.env.get("SUPABASE_SERVICE_ROLE_KEY");
    if (!supabaseUrl || !serviceRoleKey) throw new Error("missing_supabase_env");

    const supabase = createClient(supabaseUrl, serviceRoleKey, { auth: { persistSession: false } });

    const authedRider = await requireAuthRider(supabase, req);
    if (authedRider.id !== rider_id) {
      return jsonResponse({ success: false, reason: "unauthorized" }, 401);
    }

    // Load order
    const { data: order, error: orderErr } = await withTimeout(
      supabase
        .from("orders")
        .select("id,rider_id,status,dealer_id,mechanic_id,quote_id,amount,distance,dealer_lat,dealer_lng,mechanic_lat,mechanic_lng")
        .eq("id", order_id)
        .maybeSingle<Order>(),
      8000,
    );
    if (orderErr) throw orderErr;
    if (!order) {
      return jsonResponse({ success: false, reason: "order_not_found" }, 404);
    }

    // Reject if already assigned or in later status
    const laterStatuses = [
      "rider_assigned",
      "rider_at_pickup",
      "picked_up",
      "in_transit",
      "rider_at_delivery",
      "delivered",
      "disputed",
      "completed",
      "cancelled",
    ];

    const isLater = laterStatuses.includes(order.status);
    if (order.rider_id !== null || isLater || order.status !== "pending_rider") {
      return jsonResponse({ success: false, reason: "order_taken" }, 409);
    }

    const amount = toNumber(order.amount);
    let quoteItems: unknown[] = [];
    if (order.quote_id) {
      const { data: quote, error: quoteErr } = await withTimeout(
        supabase
          .from("quotes")
          .select("quote_details")
          .eq("id", order.quote_id)
          .maybeSingle<QuoteRow>(),
        8000,
      );
      if (quoteErr) throw quoteErr;
      quoteItems = parseQuoteDetails(quote?.quote_details);
    }

    const delivery_fee = calculateDeliveryFee(order);
    const platform_fee = roundMoney(calculateMrpTotal(quoteItems, amount) * 0.05);
    const total_amount = roundMoney(amount + delivery_fee + platform_fee);

    // One safe transactional flow:
    // Atomically assign only if still unassigned + pending_rider.
    const { data: updatedRows, error: updErr } = await withTimeout(
      supabase
        .from("orders")
        .update({ rider_id, status: "rider_assigned", delivery_fee, platform_fee, total_amount })
        .eq("id", order_id)
        .is("rider_id", null)
        .eq("status", "pending_rider")
        .select("id"),
      8000,
    );
    if (updErr) throw updErr;
    if (!updatedRows || updatedRows.length === 0) {
      return jsonResponse({ success: false, reason: "order_taken" }, 409);
    }

    // Fetch dealer & mechanic phones
    const { data: dealerPhoneData, error: dealerErr } = await withTimeout(
      supabase.from("users").select("phone").eq("id", order.dealer_id).maybeSingle(),
      8000,
    );
    if (dealerErr) throw dealerErr;

    const { data: mechanicPhoneData, error: mechErr } = await withTimeout(
      supabase.from("users").select("phone").eq("id", order.mechanic_id).maybeSingle(),
      8000,
    );
    if (mechErr) throw mechErr;

    const dealerPhone = (dealerPhoneData as UserPhone | null)?.phone;
    const mechanicPhone = (mechanicPhoneData as UserPhone | null)?.phone;

    const dealerMsg = `Your order ${order_id} has been assigned to a rider.`;
    const mechMsg = `Your order ${order_id} rider has been assigned.`;

    // Send WhatsApp notifications
    await Promise.all([
      dealerPhone ? sendWhatsAppText(dealerPhone, dealerMsg) : Promise.resolve(),
      mechanicPhone ? sendWhatsAppText(mechanicPhone, mechMsg) : Promise.resolve(),
    ]);

    return jsonResponse({ success: true, order_id, status: "rider_assigned" });
  } catch (err) {
    const msg = err instanceof Error ? err.message : String(err);
    console.error("rider-accept-order error:", msg);
    return jsonResponse({ success: false, reason: "server_error", message: msg }, 500);
  }
});

